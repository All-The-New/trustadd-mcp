  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "trust",
    "agent",
    "erc8004",
    "x402",
    "mpp",
    "tempo",
    "claude",
    "ai-agent",
    "blockchain"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/All-The-New/trustadd",
    "directory": "packages/trustadd-mcp"
  },
  "license": "MIT"
